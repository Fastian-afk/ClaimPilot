# UiPath Configuration
UIPATH_CLOUD_URL=https://cloud.uipath.com
UIPATH_TENANT_ID=your_tenant_id
UIPATH_CLIENT_ID=your_client_id
UIPATH_CLIENT_SECRET=your_client_secret
UIPATH_ORG_ID=your_org_id

# Maestro Configuration
MAESTRO_CASE_DEFINITION_ID=your_case_definition_id
MAESTRO_API_URL=https://cloud.uipath.com/your_org/your_tenant/maestro_/api

# Fraud Detection Thresholds
FRAUD_HIGH_RISK_THRESHOLD=0.75
FRAUD_MEDIUM_RISK_THRESHOLD=0.45
AUTO_APPROVE_MAX_AMOUNT=5000

# External API Keys (mock/simulated)
POLICY_DB_API_URL=http://localhost:8080/api/policies
PAYMENT_GATEWAY_URL=http://localhost:8080/api/payments
NOTIFICATION_SERVICE_URL=http://localhost:8080/api/notifications

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/claimpilot.log
